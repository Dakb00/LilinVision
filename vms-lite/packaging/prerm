#!/bin/sh
set -e

# --- LilinVision vms-lite Pre-Removal Script ---

case "$1" in
    remove|upgrade|deconfigure)
        echo "Stopping vms-lite service..."
        systemctl stop vms-lite || true
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0
